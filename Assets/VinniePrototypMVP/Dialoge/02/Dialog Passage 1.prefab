  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1b062873b8e7cd04e8d8acd7bf2a2ff3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Justin.ActionDialog
  backGround: 0
  jumpToAction: 0
  nextAction: {fileID: 0}
  dialogList:
  - speaker: Vinnie
    text: _favoriteColor mag ich auch sehr.
    speakerImage: {fileID: 21300000, guid: da0f4ef2e2877f4459a26dc3c2d6ec88, type: 3}
    backgroundImage: {fileID: 0}
    objectToAnimate: Vinnie
    object2ToAnimate: 
    trigger: Surprise
    trigger2: 
    animationSpeed: 1
    animation2Speed: 0.5
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "Oh, schau her. Jetzt haben wir ein Symbol in deiner Lieblingsfarbe. Vielleicht
      hei\xDFt das, du sollst die T\xFCr \xF6ffnen."
    speakerImage: {fileID: 21300000, guid: da0f4ef2e2877f4459a26dc3c2d6ec88, type: 3}
    backgroundImage: {fileID: 0}
    objectToAnimate: Vinnie
    object2ToAnimate: 
    trigger: Turn
    trigger2: 
    animationSpeed: 0.75
    animation2Speed: 0.5
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "Die erste T\xFCre habe ich mit einem Trick aufbekommen, den ich in meiner
      Ausbildung gelernt habe. Er hilft mir mich zu beruhigen. "
    speakerImage: {fileID: 21300000, guid: da0f4ef2e2877f4459a26dc3c2d6ec88, type: 3}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0.5
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "Ehrlichgesagt. Ich war doch ganz sch\xF6n aufgeregt vorhin. "
    speakerImage: {fileID: 21300000, guid: da0f4ef2e2877f4459a26dc3c2d6ec88, type: 3}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0.5
    clip: {fileID: 0}
    clip2: {fileID: 0}
