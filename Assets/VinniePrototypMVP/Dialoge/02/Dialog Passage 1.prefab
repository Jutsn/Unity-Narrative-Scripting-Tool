  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Justin.ActionDialog
  backGround: 0
  jumpToAction: 0
  nextAction: {fileID: 0}
  dialogList:
  - speaker: Vinnie
    text: "Ich bekomme die T\xFCr nicht auf. Was wohl dieses Symbol bedeutet?"
    speakerImage: {fileID: 21300000, guid: da0f4ef2e2877f4459a26dc3c2d6ec88, type: 3}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 1
    animation2Speed: 1
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "Auf der ersten T\xFCr war auch schon ein Symbol zu sehen. Das war in meiner
      Lieblingsfarbe Rot eingef\xE4rbt. "
    speakerImage: {fileID: 21300000, guid: da0f4ef2e2877f4459a26dc3c2d6ec88, type: 3}
    backgroundImage: {fileID: 0}
    objectToAnimate: Vinnie
    object2ToAnimate: 
    trigger: Turn
    trigger2: 
    animationSpeed: 1
    animation2Speed: 1
    clip: {fileID: 0}
    clip2: {fileID: 0}
