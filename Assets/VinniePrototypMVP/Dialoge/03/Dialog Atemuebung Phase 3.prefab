--- !u!114 &7578479245296035819
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7822691120735614595}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1b062873b8e7cd04e8d8acd7bf2a2ff3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Justin.ActionDialog
  backGround: 0
  jumpToAction: 0
  nextAction: {fileID: 0}
  dialogList:
  - speaker: Vinnie
    text: Huch! Jetzt ist es weg.
    speakerImage: {fileID: 0}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "Aber keine Sorge. Du hast ja gerade ge\xFCbt es dir vorzustellen."
    speakerImage: {fileID: 0}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: Und da du mir vorhin geholfen hast, werde ich dir jetzt immer aller 2,5
      Sekunden ein Zeichen geben.
    speakerImage: {fileID: 0}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "H\xF6r genau hin und versuch synchron zu dem Ton des Spielzeugs zu atmen."
    speakerImage: {fileID: 0}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0
    clip: {fileID: 0}
    clip2: {fileID: 0}
