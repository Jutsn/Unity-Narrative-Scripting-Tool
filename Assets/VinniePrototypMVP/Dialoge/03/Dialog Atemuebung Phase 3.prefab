--- !u!114 &7868871378115489452
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7822691120735614595}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1b062873b8e7cd04e8d8acd7bf2a2ff3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Justin.ActionDialog
  backGround: 0
  jumpToAction: 0
  nextAction: {fileID: 0}
  dialogList:
  - speaker: Vinnie
    text: "Gut dann schlie\xDF jetzt mal die Augen und versuch dir das Quadrat hier
      vor deinem inneren Auge vorzustellen."
    speakerImage: {fileID: 0}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0
    clip: {fileID: 0}
    clip2: {fileID: 0}
  - speaker: Vinnie
    text: "Lass dir ruhig Zeit bis du es klar vor dir siehst. Wenn du bereit bist,
      \xF6ffne die Augen wieder und dr\xFCck **Weiter**."
    speakerImage: {fileID: 0}
    backgroundImage: {fileID: 0}
    objectToAnimate: 
    object2ToAnimate: 
    trigger: 
    trigger2: 
    animationSpeed: 0
    animation2Speed: 0
    clip: {fileID: 0}
    clip2: {fileID: 0}
